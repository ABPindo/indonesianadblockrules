{
  "name": "indonesianadblockrules",
  "version": "1.0.0",
  "private": true,
  "description": "ABPindo - Filter tambahan untuk EasyList memblokir iklan berbahasa Indonesia dan Malaysia",
  "homepage": "https://github.com/ABPindo/indonesianadblockrules#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/ABPindo/indonesianadblockrules.git"
  },
  "license": "GPL-3.0-or-later",
  "overrides": {
    "@adguard/scriptlets": {
      "js-yaml": "3.15.0"
    },
    "minimatch": {
      "brace-expansion": "2.1.2"
    }
  },
  "devDependencies": {
    "@adguard/aglint": "^2.1.3",
    "@adguard/dead-domains-linter": "latest"
  },
  "scripts": {
    "lint": "bash tools/lint.sh",
    "lint:win": "pwsh tools/lint.ps1",
    "format": "fop -n src/",
    "build": "bash tools/build.sh all",
    "build:abp": "bash tools/build.sh abp",
    "build:dns": "bash tools/build.sh dns",
    "check": "npm run lint && npm run build",
    "check:duplicates": "python tools/find_duplicates.py --strict",
    "check:redundant": "node tools/run-redundancy-check.js",
    "clean": "rm -f subscriptions/*.txt && echo 'Cleaned subscriptions/'",
    "setup": "bash tools/install_tools.sh"
  }
}
